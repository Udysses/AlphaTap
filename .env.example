# Alpha Vantage — required for get_price (stocks), get_news, get_context_bundle
# Free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED (St. Louis Fed) — required for get_macro_calendar
# Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_key_here

# CoinGecko — optional; the free public API tier works without a key.
# Pro key unlocks higher rate limits: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
